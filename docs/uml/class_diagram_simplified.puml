@startuml
skinparam classAttributeIconSize 0

package "server" {
  class FastAPIApp {
    +lifespan()
  }
  class Dependencies {
    +get_auth_service()
    +get_current_user()
    +get_admin_user()
    +rate_limit()
  }
  class CalculationRequest
  class ServerMapper {
    +calculation_request_to_input()
  }
}

package "auth" {
  class AuthService {
    +ensure_default_admin()
    +login()
    +create_user()
    +change_password()
    +change_user_role()
  }
  class SessionManager {
    -_lock: RLock
    +cleanup()
    -_cleanup_unsafe()
    +create_session()
    +get_user()
    +revoke()
  }
}

package "calculation" {
  class CalculationInput
  class CalculationResult
  class CalculationOrchestrator {
    +run_full_calculation()
  }
  class MathCore {
    +calc_tes_efficiency()
    +calc_block_efficiency()
  }
  class Constants
}

package "audit" {
  class AuditEvent {
    +remote_sent
    +to_dict()
  }
  class AuditLogger {
    +get_audit_logger()
    +audit_event()
  }
}

package "client" {
  class MainWindow
  class ApiClient
}

FastAPIApp --> Dependencies
Dependencies ..> AuthService : DI
MainWindow --> ApiClient
ApiClient --> FastAPIApp : HTTP(S)
CalculationRequest --> ServerMapper
ServerMapper --> CalculationInput
CalculationOrchestrator --> MathCore
MathCore --> Constants
MathCore ..> CalculationInput
MathCore ..> CalculationResult
AuthService --> SessionManager
AuditLogger --> AuditEvent : replace(remote_sent)
@enduml
