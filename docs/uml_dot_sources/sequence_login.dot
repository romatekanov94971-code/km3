digraph sequence_login {
	graph [bgcolor=white nodesep=0.55 pad=0.2 rankdir=LR ranksep=0.65]
	node [color="#334155" fillcolor=white fontname="DejaVu Sans" fontsize=12 shape=box style="rounded,filled"]
	edge [color="#475569" fontname="DejaVu Sans" fontsize=10]
	"Пользователь" [label="Пользователь"]
	LoginWindow [label=LoginWindow]
	ApiClient [label=ApiClient]
	"/auth/login" [label="/auth/login"]
	AuthService [label=AuthService]
	UserRepository [label=UserRepository]
	SessionManager [label=SessionManager]
	AuditSinks [label=AuditSinks]
	"Пользователь" -> LoginWindow [label="логин + пароль"]
	LoginWindow -> ApiClient [label="login()"]
	ApiClient -> "/auth/login" [label=POST]
	"/auth/login" -> AuthService [label=login]
	AuthService -> UserRepository [label=get_by_username]
	UserRepository -> AuthService [label=UserRecord]
	AuthService -> SessionManager [label=create_session]
	AuthService -> AuditSinks [label="login_success/failed"]
	AuthService -> "/auth/login" [label="token + user"]
	"/auth/login" -> ApiClient [label=JSON]
	ApiClient -> LoginWindow [label="OK/error"]
}
