digraph sequence_calculation {
	graph [bgcolor=white nodesep=0.55 pad=0.2 rankdir=LR ranksep=0.65]
	node [color="#334155" fillcolor=white fontname="DejaVu Sans" fontsize=12 shape=box style="rounded,filled"]
	edge [color="#475569" fontname="DejaVu Sans" fontsize=10]
	"Пользователь" [label="Пользователь"]
	MainWindow [label=MainWindow]
	ApiClient [label=ApiClient]
	"/calc/run" [label="/calc/run"]
	AuthDep [label=AuthDep]
	Mapper [label=Mapper]
	Orchestrator [label=Orchestrator]
	MathCore [label=MathCore]
	TraceBuilder [label=TraceBuilder]
	HistoryRepo [label=HistoryRepo]
	AuditSinks [label=AuditSinks]
	ChartsWindow [label=ChartsWindow]
	"Пользователь" -> MainWindow [label="ввод параметров"]
	MainWindow -> ApiClient [label="run_calculation(payload)"]
	ApiClient -> "/calc/run" [label="POST JSON + token"]
	"/calc/run" -> AuthDep [label="проверка сессии"]
	AuthDep -> "/calc/run" [label=AuthenticatedUser]
	"/calc/run" -> Mapper [label="DTO → CalculationInput"]
	Mapper -> Orchestrator [label=run_full_calculation]
	Orchestrator -> MathCore [label=calc_tes_efficiency]
	MathCore -> TraceBuilder [label="factors + formula data"]
	TraceBuilder -> Orchestrator [label=calculation_trace]
	Orchestrator -> "/calc/run" [label=FullCalculationResult]
	"/calc/run" -> HistoryRepo [label="save input/result"]
	"/calc/run" -> AuditSinks [label=audit_event]
	"/calc/run" -> ApiClient [label="JSON result"]
	ApiClient -> MainWindow [label=result]
	MainWindow -> ChartsWindow [label="графики + trace"]
}
